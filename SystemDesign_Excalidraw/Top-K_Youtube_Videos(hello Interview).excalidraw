      "boundElements": [],
      "updated": 1756081149230,
      "link": null,
      "locked": false,
      "text": "- A scheduled batch job\n- Reads from warm storage (older segments only).\n- Transforms into cold-storage format (columnar/Parquet).\n- Writes/pushes to object storage.\n- Updates metadata/index so that queries know where to look.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- A scheduled batch job\n- Reads from warm storage (older segments only).\n- Transforms into cold-storage format (columnar/Parquet).\n- Writes/pushes to object storage.\n- Updates metadata/index so that queries know where to look.",
      "autoResize": true,
      "lineHeight": 1.25
    },
