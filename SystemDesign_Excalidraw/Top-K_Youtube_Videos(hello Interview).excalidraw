    {
      "type": "text",
      "version": 596,
      "versionNonce": 1231439929,
      "index": "bA8",
      "isDeleted": false,
      "id": "YiFCCTxRjkcTncsJJ1o52",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 6662.648612623021,
      "y": 17552.573981352136,
      "strokeColor": "#1971c2",
