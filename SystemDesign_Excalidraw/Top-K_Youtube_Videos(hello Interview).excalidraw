      "boundElements": [],
      "updated": 1728526247337,
      "link": null,
      "locked": false,
      "fontSize": 52.26136363636351,
      "fontFamily": 5,
      "text": "** Database Tables **\n- Users: user_id, email, name, phone_number\n\n- Stocks: stock_id, symbol, name, last_price, timestamp\n\n- Subscriptions: subscription_id, user_id, stock_id\n\n- Rules:\n  rule_id, subscription_id, \n  rule_type (e.g., price above, price below, moving average), \n  operator (e.g., >, <), \n  threshold_value, status (active, triggered)\n  created_at\n\n- Notifications:\n  notification_id, user_id, rule_id, message, \n  timestamp, status (sent, failed)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "** Database Tables **\n- Users: user_id, email, name, phone_number\n\n- Stocks: stock_id, symbol, name, last_price, timestamp\n\n- Subscriptions: subscription_id, user_id, stock_id\n\n- Rules:\n  rule_id, subscription_id, \n  rule_type (e.g., price above, price below, moving average), \n  operator (e.g., >, <), \n  threshold_value, status (active, triggered)\n  created_at\n\n- Notifications:\n  notification_id, user_id, rule_id, message, \n  timestamp, status (sent, failed)",
      "autoResize": true,
      "lineHeight": 1.25
    },
