      "fontSize": 53.29762316734414,
      "fontFamily": 5,
      "text": " - User registration and authentication\n - Restaurant onboarding and menu management\n - Order placement and tracking\n - Payment processing\n - Delivery driver assignment and tracking\n - Rating and review system for restaurants and drivers\n - Search and filter functionality for restaurants and menu items\n - Notifications for order status updates\n - Admin Panel: Restaurant manage menus, availability, and delivery settings.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " - User registration and authentication\n - Restaurant onboarding and menu management\n - Order placement and tracking\n - Payment processing\n - Delivery driver assignment and tracking\n - Rating and review system for restaurants and drivers\n - Search and filter functionality for restaurants and menu items\n - Notifications for order status updates\n - Admin Panel: Restaurant manage menus, availability, and delivery settings.",
      "autoResize": true,
      "lineHeight": 1.25
    },
