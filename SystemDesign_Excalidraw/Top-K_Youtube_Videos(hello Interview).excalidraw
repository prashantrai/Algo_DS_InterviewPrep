    {
      "type": "text",
      "version": 675,
      "versionNonce": 55702434,
      "index": "bBa",
      "isDeleted": false,
      "id": "x95VYEA51TADqRhppnhIM",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 5109.58500043859,
      "y": 28130.95981508206,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 973.3521958499973,
      "height": 644.6256007195233,
      "seed": 2015695906,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1729142640773,
      "link": null,
      "locked": false,
      "fontSize": 32.23128003597614,
      "fontFamily": 5,
      "text": "Why:\n - Fully managed: scales automatically.\n - Fast lookups: Offers consistent single-digit \n       millisecond performance for lookups by primary key.\n - Global secondary indexes: Can be used to efficiently \n    query stock-specific rules.\n - Built-in caching: DynamoDB Accelerator (DAX) for \n     reducing read latency.\nData Model:\n - Partition rules by stock symbol and secondary \n    index on rule type or threshold value.\n - Supports fetching millions of records quickly, \n     as it's designed for key-value access patterns.\nCaveats:\n - Expensive for very high data volumes compared \n   to self-hosted solutions like Cassandra.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why:\n - Fully managed: scales automatically.\n - Fast lookups: Offers consistent single-digit \n       millisecond performance for lookups by primary key.\n - Global secondary indexes: Can be used to efficiently \n    query stock-specific rules.\n - Built-in caching: DynamoDB Accelerator (DAX) for \n     reducing read latency.\nData Model:\n - Partition rules by stock symbol and secondary \n    index on rule type or threshold value.\n - Supports fetching millions of records quickly, \n     as it's designed for key-value access patterns.\nCaveats:\n - Expensive for very high data volumes compared \n   to self-hosted solutions like Cassandra.",
      "autoResize": true,
      "lineHeight": 1.25
    },
