      "height": 630,
      "seed": 1870620986,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1721975624193,
      "link": null,
      "locked": false,
      "fontSize": 36,
      "fontFamily": 5,
      "text": "DB Design\n - Users (user_id, …)\n - Devices (device_id, user_id, …)\n - Media\n    media_id (PK)\n    device_id (FK)\n    user_id (FK)\n    media_type: e.g., image, video\n    media_url: URL where the media file is stored\n    thumbnail_url: thumbnail image URL (for videos)\n    size: Size of the media file in bytes\n    format: e.g., MP4, JPEG\n    created_at\n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DB Design\n - Users (user_id, …)\n - Devices (device_id, user_id, …)\n - Media\n    media_id (PK)\n    device_id (FK)\n    user_id (FK)\n    media_type: e.g., image, video\n    media_url: URL where the media file is stored\n    thumbnail_url: thumbnail image URL (for videos)\n    size: Size of the media file in bytes\n    format: e.g., MP4, JPEG\n    created_at\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
