    {
      "type": "text",
      "version": 49,
      "versionNonce": 780468089,
      "index": "b98",
      "isDeleted": false,
      "id": "GvQLlbnD_y7X4tWwGcpw7",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 307.71589287966447,
      "y": 17667.430219802285,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "width": 1632.65283203125,
      "height": 495.7157553364189,
      "seed": 1929215511,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1727658474062,
      "link": null,
      "locked": false,
      "fontSize": 56.653229181305015,
      "fontFamily": 5,
      "text": "- High availability (99.99% uptime)\n- Low latency (< 100ms response time for most operations)\n- Scalability to handle millions of users and orders\n- Data consistency and integrity\n- Security (data encryption, authentication, authorization)\n- Fault tolerance and disaster recovery\n- Compliance with data protection regulations (e.g., GDPR)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- High availability (99.99% uptime)\n- Low latency (< 100ms response time for most operations)\n- Scalability to handle millions of users and orders\n- Data consistency and integrity\n- Security (data encryption, authentication, authorization)\n- Fault tolerance and disaster recovery\n- Compliance with data protection regulations (e.g., GDPR)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "type": "text",
