    {
      "type": "text",
      "version": 219,
      "versionNonce": 963305863,
      "index": "aS",
      "isDeleted": false,
      "id": "LJSIMPT0UfYaI77DYHtmC",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 1108,
      "y": 481,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "width": 169.9678955078125,
      "height": 60,
      "seed": 127794840,
      "groupIds": [],
