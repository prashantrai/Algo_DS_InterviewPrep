    {
      "id": "vIVwNlwVytBhTvGyU_Maa",
      "type": "text",
      "x": 270.7992729068883,
      "y": 22485.019225994405,
      "width": 2160.9807369709015,
      "height": 119.91257139200013,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bG2",
      "roundness": null,
      "seed": 75276922,
      "version": 306,
      "versionNonce": 766823846,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1737527274937,
      "link": null,
      "locked": false,
      "text": "How do we prevent multiple ride requests from being sent to the same driver simultaneously?\nRefer here: https://www.hellointerview.com/learn/system-design/problem-breakdowns/uber",
      "fontSize": 47.96502855680005,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How do we prevent multiple ride requests from being sent to the same driver simultaneously?\nRefer here: https://www.hellointerview.com/learn/system-design/problem-breakdowns/uber",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "gNn2K-7PiaPLaZoiRLF2m",
      "type": "text",
      "x": 276.60647354559705,
      "y": 22399.462988021533,
      "width": 672.4638863418977,
      "height": 62.61304219511356,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bG3",
      "roundness": null,
      "seed": 831409894,
      "version": 98,
      "versionNonce": 1962008358,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1737527271816,
      "link": null,
      "locked": false,
      "text": "MISSING REQUIREMENTS",
      "fontSize": 50.09043375609082,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "MISSING REQUIREMENTS",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "jS_x1VR747tidNoSTT81s",
      "type": "text",
      "x": 2654.3095095214508,
      "y": 23695.119010224065,
      "width": 2295.50439453125,
      "height": 351.52553916591916,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bG5",
      "roundness": null,
      "seed": 60792058,
      "version": 291,
      "versionNonce": 1386628410,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1737527708911,
      "link": null,
      "locked": false,
      "text": "Distributed message queue system like Kafka, which allows us to commit the offset of the message \nin the queue only after we have successfully found a match. This way, if the Ride Matching Service \ngoes down, the match request would still be in the queue, and a new instance of the service would \npick it up. This approach ensures that no ride requests are lost due to service failures and \nprovides fault tolerance to our system.\n",
      "fontSize": 46.87007188878922,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Distributed message queue system like Kafka, which allows us to commit the offset of the message \nin the queue only after we have successfully found a match. This way, if the Ride Matching Service \ngoes down, the match request would still be in the queue, and a new instance of the service would \npick it up. This approach ensures that no ride requests are lost due to service failures and \nprovides fault tolerance to our system.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "3C7SPri4cqah2hGVx3po5",
      "type": "text",
      "x": -618.3763167032081,
      "y": 49994.00865057312,
      "width": 1905.959228515625,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
