    {
      "id": "b90LookR4ATGqrSZapA8a",
      "type": "text",
      "x": 4302.518179886663,
      "y": 62642.43940732658,
      "width": 1655.581506197084,
      "height": 244.5959509166566,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bJo",
      "roundness": null,
      "seed": 1809172520,
      "version": 200,
      "versionNonce": 113363288,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1756136116183,
      "link": null,
      "locked": false,
      "text": "Using a Hot-Warm architecture is a very common and recommended \nproduction deployment for OpenSearch/Elasticsearch, especially for a \nsystem like this LinkedIn inverted index.\n\nIt's a cost-effective way to balance performance needs with the large volume of data.",
      "fontSize": 39.135352146665106,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Using a Hot-Warm architecture is a very common and recommended \nproduction deployment for OpenSearch/Elasticsearch, especially for a \nsystem like this LinkedIn inverted index.\n\nIt's a cost-effective way to balance performance needs with the large volume of data.",
      "autoResize": true,
      "lineHeight": 1.25
    },
