      "fontSize": 36,
      "fontFamily": 5,
      "text": "client(Ingestion) -> Chunking -> Segmentation -> Transcoding -> ABR Packaging+ManifestFile Creation -> Object Storage -> CDN",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "client(Ingestion) -> Chunking -> Segmentation -> Transcoding -> ABR Packaging+ManifestFile Creation -> Object Storage -> CDN",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 180,
      "versionNonce": 1562596951,
      "index": "b7F",
      "isDeleted": false,
      "id": "Kh0nwGDqVF1_nNlZdx68j",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 3813.6887526170804,
      "y": 10965.339176842726,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "width": 880.919677734375,
      "height": 1710,
      "seed": 2121805369,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1722446542674,
      "link": null,
      "locked": false,
      "fontSize": 36,
      "fontFamily": 5,
      "text": "IoT Devices Stream Data (RTSP)\n            ↓\n     Load Balancer\n            ↓\n  Media Ingestion Nodes\n            ↓\nQueue for Chunking (Kafka, RabbitMQ, etc.)\n            ↓\n       Chunking\n            ↓\nQueue for Segmentation (Kafka, RabbitMQ, etc.)\n            ↓\n      Segmentation\n            ↓\nQueue for Transcoding (Kafka, RabbitMQ, etc.)\n            ↓\n      Transcoding\n            ↓\nQueue for ABR Packaging (Kafka, RabbitMQ, etc.)\n            ↓\n    ABR Packaging\n  (Manifest File Creation)\n            ↓\nQueue for Storage (Kafka, RabbitMQ, etc.)\n            ↓\n   ┌──────┐\n   │  Object     │\n   │  Storage    │\n   └──────┘\n            ↓\n   Metadata Storage (REST)\n            ↓\nClient Requests Playback (REST)\n            ↓\n    Content Delivery Network (CDN)\n            ↓\nAdaptive Bit Rate Streaming\n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "IoT Devices Stream Data (RTSP)\n            ↓\n     Load Balancer\n            ↓\n  Media Ingestion Nodes\n            ↓\nQueue for Chunking (Kafka, RabbitMQ, etc.)\n            ↓\n       Chunking\n            ↓\nQueue for Segmentation (Kafka, RabbitMQ, etc.)\n            ↓\n      Segmentation\n            ↓\nQueue for Transcoding (Kafka, RabbitMQ, etc.)\n            ↓\n      Transcoding\n            ↓\nQueue for ABR Packaging (Kafka, RabbitMQ, etc.)\n            ↓\n    ABR Packaging\n  (Manifest File Creation)\n            ↓\nQueue for Storage (Kafka, RabbitMQ, etc.)\n            ↓\n   ┌──────┐\n   │  Object     │\n   │  Storage    │\n   └──────┘\n            ↓\n   Metadata Storage (REST)\n            ↓\nClient Requests Playback (REST)\n            ↓\n    Content Delivery Network (CDN)\n            ↓\nAdaptive Bit Rate Streaming\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
