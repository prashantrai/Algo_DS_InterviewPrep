      "seed": 783789400,
      "version": 404,
      "versionNonce": 528261720,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1756136116183,
      "link": null,
      "locked": false,
      "text": "- Add: prepare batch, group them by shard\nand sends in one big, bulk request.\n\n- Del/Update: sends a _delete command to \nOpenSearch with the post_id. \nOpenSearch handles marking that entire \ndocument as deleted.\n",
      "fontSize": 39.73065771095571,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Add: prepare batch, group them by shard\nand sends in one big, bulk request.\n\n- Del/Update: sends a _delete command to \nOpenSearch with the post_id. \nOpenSearch handles marking that entire \ndocument as deleted.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
