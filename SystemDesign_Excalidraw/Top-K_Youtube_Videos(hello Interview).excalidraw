    {
      "type": "text",
      "version": 89,
      "versionNonce": 1265547225,
      "index": "b9C",
      "isDeleted": false,
      "id": "EgCLVWX8ngZP3Z4nqmZOG",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 303.47493883464244,
      "y": 18379.91049936596,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "width": 1537.4374046325684,
      "height": 691.0377751797512,
      "seed": 345342807,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1727658861359,
      "link": null,
      "locked": false,
      "fontSize": 55.283022014380094,
      "fontFamily": 5,
      "text": "Assuming 1 Million daily active users:\n  - Daily orders: 500,000\n  - Peak orders per hour: 50,000\n  - Average order size: 5 KB\n  - Daily data generation: 500,000 * 5 KB = 2.5 GB\n  - Storage needed per year: 2.5 GB * 365 = 912.5 GB\n\nBandwidth estimation:\n  - Peak requests per second: 50,000 / 3600 ≈ 14 RPS\n  - Assuming 1 KB per request: 14 KB/s or 0.112 Mbps",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Assuming 1 Million daily active users:\n  - Daily orders: 500,000\n  - Peak orders per hour: 50,000\n  - Average order size: 5 KB\n  - Daily data generation: 500,000 * 5 KB = 2.5 GB\n  - Storage needed per year: 2.5 GB * 365 = 912.5 GB\n\nBandwidth estimation:\n  - Peak requests per second: 50,000 / 3600 ≈ 14 RPS\n  - Assuming 1 KB per request: 14 KB/s or 0.112 Mbps",
      "autoResize": true,
      "lineHeight": 1.25
    },
