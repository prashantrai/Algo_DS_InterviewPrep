    {
      "type": "text",
      "version": 330,
      "versionNonce": 2103557625,
      "index": "b21",
      "isDeleted": false,
      "id": "gLxHU50dXMaENDkTkdDVd",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 2059.6115128787615,
      "y": 3626.857616280382,
