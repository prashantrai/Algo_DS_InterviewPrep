    {
      "type": "text",
      "version": 414,
      "versionNonce": 250046147,
      "index": "bD5",
      "isDeleted": false,
      "id": "02FeVWIkSmW9qVyHUDRwQ",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 57.218617126295385,
      "y": 35564.46222838893,
      "strokeColor": "#e03131",
      "backgroundColor": "#a5d8ff",
      "width": 835.5119781495993,
