    {
      "id": "M20QIymsIUj_PEngaZ2Ra",
      "type": "text",
      "x": 3328.944398356822,
      "y": 63356.28144852224,
      "width": 850.2218017578125,
      "height": 397.3065771095571,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
